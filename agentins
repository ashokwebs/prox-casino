================================================================================
PROJECT STRUCTURE
================================================================================

src/
  main.rs                    — Entry point, terminal setup, main loop
  app/
    mod.rs                   — App state machine, all event handling, game bridging
  core/
    mod.rs
    config.rs                — Constants (START_CHIPS, DAILY_BONUS, TICK_RATE_MS, etc.)
  games/
    mod.rs
    traits.rs                — GameEngine trait (future-ready)
    blackjack/
      mod.rs                 — Blackjack game engine (cards, hands, dealer AI, rounds)
    slots/
      mod.rs                 — Slots game engine (reels, symbols, payouts, spinning)
  models/
    mod.rs
    game.rs                  — GameKind enum (future-ready)
    mode.rs                  — Mode enum (Offline, Online)
    player.rs                — OfflinePlayer, OnlinePlayer, daily bonus
    stats.rs                 — PlayerStats (tracked stats)
  network/
    mod.rs
    client.rs                — OnlineClient stub (future-ready)
    protocol.rs              — ClientAction, ServerEvent enums (future-ready)
  security/
    mod.rs                   — SecurityArchitecture docs (future-ready)
  services/
    mod.rs
    save.rs                  — SaveService (load/save wrapper)
  storage/
    mod.rs
    local.rs                 — SaveStore with atomic JSON writes to ~/.local/share/prox-casino/
    sqlite.rs                — SqliteStore stub (future-ready)
  ui/
    mod.rs                   — Main draw() function, layout routing
    theme.rs                 — ProxTheme (cyberpunk default, theming system)
    animations/
      mod.rs                 — Animation helpers (spinner, pulse, slot reel frames)
    components/
      mod.rs
      header.rs              — Header with mode badge and tab navigation
      footer.rs              — Footer with mode status
      notifications.rs       — Notification panel
      modal.rs               — Modal dialog component (future-ready)
    screens/
      mod.rs
      dashboard.rs           — Main hub: player profile, stats, game info
      blackjack.rs           — Blackjack table rendering
      slots.rs               — Slot machine rendering
      online.rs              — Online mode placeholder screen
  utils/
    mod.rs
    errors.rs                — ProxError enum (future-ready)
    rng.rs                   — RngPolicy struct (future-ready)

